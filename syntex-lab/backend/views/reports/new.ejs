<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header">
      <span class="header-title">Submit Bug Report</span>
      <div class="header-right">
        <a href="/reports" class="btn btn-secondary btn-sm">My Reports</a>
        <a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a>
      </div>
    </div>

    <div class="page-body">
      <div class="breadcrumb"><a href="/bug-bounty">Bug Bounty</a><span>›</span><a href="/reports">Reports</a><span>›</span><span>New</span></div>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

      <div style="display:flex;gap:24px;align-items:start;">
        <!-- Main Form -->
        <div style="flex:1;min-width:0;">
          <div class="card">
            <div class="card-header"><h3>Bug Report</h3><span style="font-size:12px;color:var(--text-muted);">All starred fields required</span></div>
            <div class="card-body">
              <form action="/reports" method="POST">

                <div class="form-group">
                  <label>Report Title <span class="form-required">*</span></label>
                  <input type="text" name="title" required placeholder='e.g. "SQL Injection in /login allows authentication bypass"' style="font-size:14px;">
                  <div class="form-hint">Format: [Vuln Type] in [Location] allows [Impact]</div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label>Vulnerability Type <span class="form-required">*</span></label>
                    <select name="vuln_type" required>
                      <option value="">— Select type —</option>
                      <optgroup label="Injection">
                        <option value="sqli">SQL Injection</option>
                        <option value="cmd_injection">Command Injection</option>
                        <option value="lfi">LFI / Path Traversal</option>
                        <option value="ssrf">SSRF</option>
                      </optgroup>
                      <optgroup label="XSS">
                        <option value="xss_reflected">XSS — Reflected</option>
                        <option value="xss_stored">XSS — Stored</option>
                        <option value="xss_dom">XSS — DOM</option>
                      </optgroup>
                      <optgroup label="Access Control">
                        <option value="idor">IDOR</option>
                        <option value="broken_access">Broken Access Control</option>
                        <option value="auth_bypass">Authentication Bypass</option>
                        <option value="csrf">CSRF</option>
                      </optgroup>
                      <optgroup label="Auth / Crypto">
                        <option value="jwt">JWT Vulnerability</option>
                        <option value="weak_crypto">Weak Cryptography</option>
                        <option value="rate_limit">Rate Limit Bypass</option>
                      </optgroup>
                      <optgroup label="Other">
                        <option value="cors">CORS Misconfiguration</option>
                        <option value="open_redirect">Open Redirect</option>
                        <option value="file_upload">File Upload Bypass</option>
                        <option value="business_logic">Business Logic</option>
                        <option value="exposure">Exposed Secrets / Files</option>
                        <option value="info_disclosure">Information Disclosure</option>
                        <option value="missing_headers">Missing Security Headers</option>
                        <option value="other">Other</option>
                      </optgroup>
                    </select>
                  </div>

                  <div class="form-group">
                    <label>Severity <span class="form-required">*</span></label>
                    <select name="severity" required id="severity-select">
                      <option value="">— Select severity —</option>
                      <option value="critical">🔴 Critical (P1) — CVSS 9.0–10.0</option>
                      <option value="high">🟠 High (P2) — CVSS 7.0–8.9</option>
                      <option value="medium">🟡 Medium (P3) — CVSS 4.0–6.9</option>
                      <option value="low">🟢 Low (P4) — CVSS 0.1–3.9</option>
                      <option value="info">⚪ Informative (P5)</option>
                    </select>
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label>CVSS Score <span style="font-size:11px;color:var(--text-muted);">(optional)</span></label>
                    <input type="number" name="cvss_score" min="0" max="10" step="0.1" placeholder="e.g. 8.5">
                    <div class="form-hint">Use <a href="https://www.first.org/cvss/calculator/3.1" target="_blank" style="color:var(--accent);">CVSS Calculator</a> to compute</div>
                  </div>
                  <div class="form-group">
                    <label>Affected URL / Endpoint <span class="form-required">*</span></label>
                    <input type="text" name="affected_url" required placeholder="e.g. POST /login or GET /search?q=">
                  </div>
                </div>

                <div class="form-group">
                  <label>Steps to Reproduce <span class="form-required">*</span></label>
                  <textarea name="steps" rows="7" required placeholder="1. Navigate to /login&#10;2. Enter username: admin'--&#10;3. Enter any password&#10;4. Click Login&#10;5. Observe: authenticated as admin without valid credentials"></textarea>
                  <div class="form-hint">Numbered steps. Must be reproducible by the triage team in &lt;5 minutes.</div>
                </div>

                <div class="form-group">
                  <label>Impact <span class="form-required">*</span></label>
                  <textarea name="impact" rows="4" required placeholder="Describe the real-world impact. What can an attacker actually do? What data is exposed? How many users are affected?"></textarea>
                </div>

                <div class="form-group">
                  <label>Proof of Concept</label>
                  <textarea name="proof_of_concept" rows="5" placeholder="Paste your payload, curl command, Burp request, or describe your PoC screenshot here.&#10;&#10;Example:&#10;curl -X POST http://syntex.local/login -d 'username=admin'"'"'--&amp;password=x'"></textarea>
                </div>

                <div class="form-group">
                  <label>Suggested Fix</label>
                  <textarea name="suggested_fix" rows="4" placeholder="What change would fix this vulnerability? Code examples are appreciated but not required."></textarea>
                </div>

                <div style="display:flex;gap:10px;padding-top:8px;">
                  <button type="submit" class="btn btn-primary btn-lg">Submit Report</button>
                  <a href="/reports" class="btn btn-secondary btn-lg">Cancel</a>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Sidebar guide -->
        <aside style="width:260px;flex-shrink:0;">
          <div class="card mb-4">
            <div class="card-header"><h3>Submission Tips</h3></div>
            <div class="card-body" style="font-size:12px;line-height:1.8;">
              <p style="font-weight:700;margin-bottom:6px;">Good reports include:</p>
              <ul style="padding-left:16px;color:var(--text-muted);">
                <li>Clear, descriptive title</li>
                <li>Exact steps — numbered</li>
                <li>Screenshot or curl command</li>
                <li>Real impact statement</li>
                <li>Suggested remediation</li>
              </ul>
              <p style="font-weight:700;margin:10px 0 6px;">Common mistakes:</p>
              <ul style="padding-left:16px;color:var(--text-muted);">
                <li>Submitting scanner output only</li>
                <li>Overstating severity</li>
                <li>Steps that don't reproduce</li>
                <li>No PoC or evidence</li>
              </ul>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><h3>Need Help?</h3></div>
            <div class="card-body" style="font-size:12px;">
              <p style="color:var(--text-muted);margin-bottom:10px;">Not sure how to exploit a vulnerability?</p>
              <a href="/hints" class="btn btn-secondary btn-sm w-100" style="margin-bottom:8px;display:block;text-align:center;">Browse Hints</a>
              <a href="/challenges" class="btn btn-secondary btn-sm w-100" style="display:block;text-align:center;">Practice Chains</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/footer') %>
