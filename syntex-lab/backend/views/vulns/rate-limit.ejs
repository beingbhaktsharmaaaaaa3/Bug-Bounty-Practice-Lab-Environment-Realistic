<%- include('../partials/navbar') %>
<main class="main-content">
  <div class="top-header"><span class="header-title">Rate Limit Lab</span>
    <div class="header-right"><a href="/profile/<%= user.id %>" class="header-user"><div class="header-avatar"><%= ((user.first_name||user.username).charAt(0)).toUpperCase() %></div></a></div>
  </div>
  <div class="page-body">
    <div class="page-header"><h1>API Rate-Limit Abuse</h1><p>Rate limiting uses IP from X-Forwarded-For — a client-controlled header.</p></div>
    <div style="max-width:900px;display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">
      <div>
        <div class="card mb-4">
          <div class="card-header"><h3>Send API Requests</h3></div>
          <div class="card-body">
            <div class="form-group"><label>X-Forwarded-For Header (custom IP)</label>
              <input type="text" id="xff" placeholder="Leave blank to use real IP" style="font-family:monospace;">
            </div>
            <div class="form-group"><label>X-Rate-Key (custom key)</label>
              <input type="text" id="ratekey" placeholder="Leave blank to use IP" style="font-family:monospace;">
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button onclick="sendReq()" class="btn btn-primary">Send 1 Request</button>
              <button onclick="send10()" class="btn btn-warning">Send 10 Rapid</button>
              <button onclick="bypass()" class="btn btn-danger">Rotate IPs (Bypass)</button>
            </div>
          </div>
        </div>
        <div class="card" style="border-color:var(--danger);">
          <div class="card-header" style="background:var(--danger-bg);"><h3>⚠️ Live Request Log</h3></div>
          <div id="log" style="font-family:monospace;font-size:11px;max-height:240px;overflow-y:auto;padding:14px;background:#1A202C;color:#68D391;border-radius:var(--radius);">Requests will appear here...</div>
        </div>
      </div>
      <div>
        <div class="card mb-4">
          <div class="card-header"><h3>Rate Limit Status</h3></div>
          <div class="card-body" style="text-align:center;padding:20px;">
            <div id="count-display" style="font-size:40px;font-weight:800;color:var(--primary);">0</div>
            <div style="color:var(--text-muted);font-size:13px;">requests / 10 limit</div>
            <div style="margin-top:12px;background:var(--border);border-radius:4px;height:8px;overflow:hidden;">
              <div id="progress" style="height:100%;background:var(--success);width:0%;transition:width 0.2s;"></div>
            </div>
            <div id="status-msg" style="margin-top:10px;font-size:12px;color:var(--text-muted);">Send requests to see rate limit in action.</div>
            <div id="flag-box" style="display:none;margin-top:12px;font-family:monospace;font-size:12px;color:var(--success);padding:10px;background:var(--success-bg);border-radius:var(--radius);"></div>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Bypass Techniques</h3></div>
          <div class="card-body" style="font-size:12px;">
            <table style="width:100%;">
              <% [
                ['X-Forwarded-For rotation','Change IP per request'],
                ['X-Rate-Key header','Supply custom key to get own bucket'],
                ['Different User-Agents','Per-UA rate limits'],
                ['Distributed IPs','Multiple source IPs'],
              ].forEach(([t,d]) => { %>
              <tr style="border-bottom:1px solid var(--border-light);">
                <td style="padding:5px 0;font-weight:600;font-size:11px;"><%= t %></td>
                <td style="padding:5px 0;color:var(--text-muted);font-size:11px;"><%= d %></td>
              </tr>
              <% }) %>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
</div><%- include('../partials/footer') %>
<script>
let totalReqs = 0;
async function sendReq(xff, ratekey) {
  const headers = {'Content-Type':'application/json'};
  const xffVal = xff || document.getElementById('xff').value;
  const rkVal  = ratekey || document.getElementById('ratekey').value;
  if (xffVal)  headers['X-Forwarded-For'] = xffVal;
  if (rkVal)   headers['X-Rate-Key']      = rkVal;
  const r = await fetch('/api/v1/rate-test', {method:'POST', headers, body:JSON.stringify({action:'test'})});
  const d = await r.json();
  const status = r.status;
  totalReqs++;
  const pct = Math.min((d.request||totalReqs)/10*100,100);
  document.getElementById('count-display').textContent = d.request || totalReqs;
  document.getElementById('progress').style.background = pct>=100?'var(--danger)':pct>=70?'var(--warning)':'var(--success)';
  document.getElementById('progress').style.width = pct+'%';
  document.getElementById('status-msg').textContent = status===429 ? '🚫 Rate limited! Change X-Forwarded-For to bypass.' : `${d.note || 'Request '+totalReqs}`;
  const log = document.getElementById('log');
  log.textContent += `[${status}] key=${d.key_used?.slice(0,20)} req=${d.request} ${d.flag?'🚩 '+d.flag:''} ${status===429?'BLOCKED':''}\n`;
  log.scrollTop = log.scrollHeight;
  if (d.flag) { const fb=document.getElementById('flag-box'); fb.style.display='block'; fb.textContent='🚩 '+d.flag; }
}
async function send10() {
  for(let i=0;i<10;i++) { await sendReq(); await new Promise(r=>setTimeout(r,50)); }
}
async function bypass() {
  const log = document.getElementById('log');
  log.textContent += '--- BYPASS: rotating IPs via X-Forwarded-For ---\n';
  for(let i=0;i<15;i++) {
    await sendReq(`10.0.${Math.floor(i/10)}.${i%256}`, '');
    await new Promise(r=>setTimeout(r,30));
  }
}
</script>
